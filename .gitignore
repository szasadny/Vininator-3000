# Data — never commit raw, intermediate, or processed datasets.
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Secrets
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.python-version

# Tooling caches
.ruff_cache/
.pytest_cache/
.mypy_cache/

# Notebooks
.ipynb_checkpoints/

# Experiment tracking (MLflow local runs)
mlruns/

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
