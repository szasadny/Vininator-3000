# Root directory for raw/, interim/, processed/ data.
# Defaults to ./data when unset.
VININATOR_DATA_DIR=./data

# Which X-Wines variant to use: test | slim | full.
# - test (default): 100 wines / 1k ratings, auto-fetched from GitHub.
# - slim:         1,007 wines / 150k ratings — manual download from Google Drive.
# - full:        100,646 wines / 21M ratings — manual download from Google Drive.
# See https://github.com/rogerioxavier/X-Wines for the Drive link.
VININATOR_XWINES_VARIANT=test

# Contact string baked into the Nominatim User-Agent. Their TOS requires a
# means of contacting the operator — either a URL (e.g. +https://github.com/...)
# or `mailto:you@example.com`. Defaults to the project's public repo URL.
# DO NOT put a personal email here in code; set it locally in your own `.env`.
VININATOR_NOMINATIM_CONTACT=+https://github.com/vininator-3000/vininator-3000
